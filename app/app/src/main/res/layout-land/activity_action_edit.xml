<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lightBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="@string/edit_action"
        app:titleTextColor="@color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp">

            <!-- 左侧：名称和坐标 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/card_background">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/action_name"
                        android:textSize="12sp"
                        android:textColor="@color/secondaryText"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:textSize="13sp"
                        android:textColor="@color/colorBlack"
                        android:background="@drawable/input_background"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:background="@drawable/card_background">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/coordinates"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorBlack"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/start_x"
                                android:textSize="11sp"
                                android:textColor="@color/secondaryText"
                                android:layout_marginBottom="4dp"/>

                            <EditText
                                android:id="@+id/etX"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:textSize="13sp"
                                android:inputType="number"
                                android:textColor="@color/colorBlack"
                                android:background="@drawable/input_background"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/start_y"
                                android:textSize="11sp"
                                android:textColor="@color/secondaryText"
                                android:layout_marginBottom="4dp"/>

                            <EditText
                                android:id="@+id/etY"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:textSize="13sp"
                                android:inputType="number"
                                android:textColor="@color/colorBlack"
                                android:background="@drawable/input_background"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutEndCoords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/dividerColor"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/end_x"
                                    android:textSize="11sp"
                                    android:textColor="@color/secondaryText"
                                    android:layout_marginBottom="4dp"/>

                                <EditText
                                    android:id="@+id/etEndX"
                                    android:layout_width="match_parent"
                                    android:layout_height="36dp"
                                    android:textSize="13sp"
                                    android:inputType="number"
                                    android:textColor="@color/colorBlack"
                                    android:background="@drawable/input_background"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/end_y"
                                    android:textSize="11sp"
                                    android:textColor="@color/secondaryText"
                                    android:layout_marginBottom="4dp"/>

                                <EditText
                                    android:id="@+id/etEndY"
                                    android:layout_width="match_parent"
                                    android:layout_height="36dp"
                                    android:textSize="13sp"
                                    android:inputType="number"
                                    android:textColor="@color/colorBlack"
                                    android:background="@drawable/input_background"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- 右侧：时间和重复 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/card_background">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/timing_settings"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorBlack"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/duration"
                                android:textSize="11sp"
                                android:textColor="@color/secondaryText"
                                android:layout_marginBottom="4dp"/>

                            <EditText
                                android:id="@+id/etDuration"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:textSize="13sp"
                                android:inputType="number"
                                android:textColor="@color/colorBlack"
                                android:background="@drawable/input_background"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ms"
                            android:textSize="12sp"
                            android:textColor="@color/secondaryText"
                            android:layout_gravity="bottom"
                            android:paddingBottom="8dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutWaitTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/wait_time"
                                android:textSize="11sp"
                                android:textColor="@color/secondaryText"
                                android:layout_marginBottom="4dp"/>

                            <EditText
                                android:id="@+id/etWaitTime"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:textSize="13sp"
                                android:inputType="number"
                                android:textColor="@color/colorBlack"
                                android:background="@drawable/input_background"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ms"
                            android:textSize="12sp"
                            android:textColor="@color/secondaryText"
                            android:layout_gravity="bottom"
                            android:paddingBottom="8dp"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:background="@drawable/card_background">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/repeat_settings"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorBlack"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/repeat"
                                android:textSize="11sp"
                                android:textColor="@color/secondaryText"
                                android:layout_marginBottom="4dp"/>

                            <EditText
                                android:id="@+id/etRepeat"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:textSize="13sp"
                                android:inputType="number"
                                android:textColor="@color/colorBlack"
                                android:background="@drawable/input_background"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/times"
                            android:textSize="12sp"
                            android:textColor="@color/secondaryText"
                            android:layout_gravity="bottom"
                            android:paddingBottom="8dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/white"
        android:gravity="center">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/cancel"
            style="@style/Widget.Button.Secondary"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/save"
            style="@style/Widget.Button.Primary"/>

    </LinearLayout>

</LinearLayout>